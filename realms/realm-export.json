{
  "realm": "cnas-sso",
  "enabled": true,
  "sslRequired": "NONE",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,

  "roles": {
    "realm": [
      {
        "name": "cards:r",
        "description": "Read cards"
      },
      {
        "name": "cards:ri",
        "description": "Read and Insert cards"
      },
      {
        "name": "cards:riu",
        "description": "Read, Insert and Update cards"
      },
      {
        "name": "cards:riud",
        "description": "Full administrator"
      }
    ]
  },

  "clients": [
    {
      "clientId": "echifa-web",
      "name": "ECHIFA Web App",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "echifa-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://167.86.79.16:3000/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "http://167.86.79.16:3000"
      ],
      "frontchannelLogout": true,
      "attributes": {
        "post.logout.redirect.uris": "http://167.86.79.16:3000/api/auth/logout##http://167.86.79.16:3000/"
      }
    },
    {
      "clientId": "segma-web",
      "name": "SEGMA Web App",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "segma-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://167.86.79.16:3001/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "http://167.86.79.16:3001"
      ],
      "frontchannelLogout": true,
      "attributes": {
        "post.logout.redirect.uris": "http://167.86.79.16:3001/api/auth/logout##http://167.86.79.16:3001/"
      }
